# Forge — provider connector proxies.
# Each variable should point at a backend route that authenticates to the
# corresponding provider and returns normalised UsageRecord[].
# Leave blank to use the deterministic baseline data.
#
# UsageRecord = { provider, model, monthKey (YYYY-MM), spendUsd, tokens,
#                 cacheHit?, errRate? }

